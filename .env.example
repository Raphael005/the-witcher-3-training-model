# Copy to .env and fill in. The training script reads these from the environment.

# Hugging Face token (needed for gated models / pushing to the Hub)
HF_TOKEN=

# Where to write training runs (overrides the config's output_root)
SFT_OUTPUT_ROOT=runs

# Optional: limit which GPUs are visible
# CUDA_VISIBLE_DEVICES=0

# Optional: Weights & Biases (only if report_to: wandb)
# WANDB_API_KEY=
# WANDB_PROJECT=witcher-sft
